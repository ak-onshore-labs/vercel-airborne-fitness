# Copy to .env and set your database URL (MongoDB).
# Example (Atlas): mongodb+srv://user:password@cluster.mongodb.net/airborne_fitness
# Example (local): mongodb://localhost:27017/airborne_fitness
# Server uses MONGODB_URI if set, otherwise DATABASE_URL.
MONGODB_URI=
# DATABASE_URL=

# Optional: set to "true" to run seed on server start (only if class_types is empty, or if RESET_SEED=true).
# Leave unset or "false" in staging/production.
# SEED_ON_START=false

# JWT (auth token after OTP verification)
# JWT_SECRET=your-secret-min-32-chars
# JWT_EXPIRES_IN=7d

# MSG91 (OTP) — production: set the same variable on your host (not only in local .env)
# MSG_API_KEY=your-msg91-auth-key
# MSG91_AUTH_KEY=...   # optional alias
# MSG91_LOG_CURL_WITH_SECRET=true   # optional: include authkey in [MSG91] send-otp curl logs (production only)

# Admin: users with userRole "ADMIN" can access admin APIs (JWT required). Set role in DB or via seed.
# Seed creates an ADMIN user (mobile 9999977777). No env needed for admin auth.

# Razorpay (payments)
# RAZORPAY_KEY_ID=rzp_test_...  (or use RAZORPAY_MID; same value – public key for Checkout)
# RAZORPAY_KEY_SECRET=...       (secret – never expose to client)
# RAZORPAY_MID=...              (optional alias for RAZORPAY_KEY_ID)
# RAZORPAY_WEBHOOK_SECRET=...    (optional; set in Razorpay Dashboard for webhook signature verification)

# --- Home page media (CDN). See client/public/media/README.md ---
# Do NOT set until each URL is verified (HTTPS, plays in browser). Omit = poster-only home.
# Client build (Vite) — prefix VITE_
# VITE_HERO_POSTER_URL=https://res.cloudinary.com/<cloud>/image/upload/.../hero-poster.webp
# VITE_HERO_VIDEO_URL=https://res.cloudinary.com/<cloud>/video/upload/.../hero-v1.mp4
# VITE_CLASS_VIDEO_AERIAL_FITNESS=https://res.cloudinary.com/<cloud>/video/upload/.../aerial-fitness-v1.mp4
# VITE_CLASS_VIDEO_AERIAL_HOOP_SILK=...
# VITE_CLASS_VIDEO_FUNCTIONAL_TRAINING=...
# VITE_CLASS_VIDEO_KIDS_AERIAL_FITNESS=...
# VITE_CLASS_VIDEO_KIDS_ADVANCE_AERIAL=...
# VITE_CLASS_VIDEO_MAT_PILATES=...
# VITE_CLASS_VIDEO_TRAMPOLINE_FITNESS=...

# Optional Phase 4 runtime overrides (GET /api/home-media) — server env, no VITE_ prefix
# HERO_POSTER_URL=
# HERO_VIDEO_URL=
# CLASS_VIDEO_AERIAL_FITNESS=
# CLASS_VIDEO_AERIAL_HOOP_SILK=
# CLASS_VIDEO_FUNCTIONAL_TRAINING=
# CLASS_VIDEO_KIDS_AERIAL_FITNESS=
# CLASS_VIDEO_KIDS_ADVANCE_AERIAL=
# CLASS_VIDEO_MAT_PILATES=
# CLASS_VIDEO_TRAMPOLINE_FITNESS=
