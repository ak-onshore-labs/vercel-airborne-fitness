# Production. Set DATABASE_URL in your host (e.g. Neon production connection string).
# Never commit .env.production. Do not seed on start.
# DATABASE_URL=...
# SEED_ON_START=false
# ADMIN_ALLOWLIST_PHONES=...
#
# OTP (MSG91): must be set in your host’s environment (Railway/Fly/VM secrets).
# npm start does not load a local .env unless you deploy one — use the platform UI.
# MSG_API_KEY=your-msg91-auth-key
# (aliases: MSG91_AUTH_KEY, MSG91_API_KEY)
